# HAT Studio Backend - Production Environment Template

# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real secrets to git!

# Server
PORT=8080
NODE_ENV=production

# Database (Update for production)
DATABASE_URL=postgresql://username:password@host:5432/hat_studio?schema=public

# JWT Configuration (Generate a strong random secret!)
# Use: openssl rand -base64 32
JWT_SECRET=replace-with-strong-random-secret

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Admin Credentials (MUST CHANGE!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=UseAStrongPassword123!

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret